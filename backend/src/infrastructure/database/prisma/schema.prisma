generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model dim_date {
  date_sk     Int      @id @default(autoincrement())
  full_date   DateTime @unique @db.Date
  year        Int?
  quarter     Int?
  month       Int?
  month_name  String?  @db.VarChar(20)
  week        Int?
  day_of_week Int?
  day_name    String?  @db.VarChar(20)
  is_weekend  Boolean?
  created_at  DateTime @default(now()) @db.Timestamp(6)

  dim_order_purchase       dim_order[] @relation("purchase_date")
  dim_order_approved       dim_order[] @relation("approved_date")
  dim_order_delivered      dim_order[] @relation("delivered_date")
  dim_order_estimated      dim_order[] @relation("estimated_date")
  fact_sales               fact_sales[]
}

model dim_customer {
  customer_sk             Int           @id @default(autoincrement())
  customer_id             String        @unique @db.VarChar(50)
  customer_unique_id      String?       @db.VarChar(50)
  customer_city           String?       @db.VarChar(100)
  customer_state          String?       @db.VarChar(2)
  customer_zip_code_prefix String?      @db.VarChar(10)
  created_at              DateTime      @default(now()) @db.Timestamp(6)
  fact_sales              fact_sales[]
}

model dim_product {
  product_sk                  Int          @id @default(autoincrement())
  product_id                  String       @unique @db.VarChar(50)
  product_category_name       String?      @db.VarChar(100)
  product_category_name_english String?    @db.VarChar(100)
  product_weight_g            Int?
  product_length_cm           Int?
  product_height_cm           Int?
  product_width_cm            Int?
  created_at                  DateTime     @default(now()) @db.Timestamp(6)
  fact_sales                  fact_sales[]
}

model dim_order {
  order_sk                      Int          @id @default(autoincrement())
  order_id                      String       @unique @db.VarChar(50)
  customer_id                   String       @db.VarChar(50)
  order_status                  String?      @db.VarChar(50)
  order_purchase_timestamp      DateTime?    @db.Timestamp(6)
  order_approved_at             DateTime?    @db.Timestamp(6)
  order_delivered_carrier_date  DateTime?    @db.Timestamp(6)
  order_delivered_customer_date DateTime?    @db.Timestamp(6)
  order_estimated_delivery_date DateTime?    @db.Timestamp(6)
  purchase_date_sk              Int?
  approved_date_sk              Int?
  delivered_date_sk             Int?
  estimated_delivery_date_sk    Int?
  created_at                    DateTime     @default(now()) @db.Timestamp(6)

  dim_date_purchase  dim_date? @relation("purchase_date", fields: [purchase_date_sk], references: [date_sk])
  dim_date_approved  dim_date? @relation("approved_date", fields: [approved_date_sk], references: [date_sk])
  dim_date_delivered dim_date? @relation("delivered_date", fields: [delivered_date_sk], references: [date_sk])
  dim_date_estimated dim_date? @relation("estimated_date", fields: [estimated_delivery_date_sk], references: [date_sk])
  fact_sales         fact_sales[]
}

model fact_sales {
  fact_sales_sk           Int       @id @default(autoincrement())
  order_sk                Int?
  customer_sk             Int?
  product_sk              Int?
  date_sk                 Int?
  order_id                String    @db.VarChar(50)
  order_item_id           Int
  item_price              Decimal   @db.Decimal(10,2)
  freight_value           Decimal   @db.Decimal(10,2) @default(0)
  total_order_value       Decimal?  @db.Decimal(10,2)
  payment_value_allocated Decimal?  @db.Decimal(10,2)
  is_canceled             Boolean?  @default(false)
  is_delivered            Boolean?  @default(false)
  is_on_time              Boolean?  @default(false)
  created_at              DateTime  @default(now()) @db.Timestamp(6)

  dim_order    dim_order?    @relation(fields: [order_sk], references: [order_sk])
  dim_customer dim_customer? @relation(fields: [customer_sk], references: [customer_sk])
  dim_product  dim_product?  @relation(fields: [product_sk], references: [product_sk])
  dim_date     dim_date?     @relation(fields: [date_sk], references: [date_sk])

  @@unique([order_id, order_item_id])
}
